      "source": [
        "# Get quarterly financial statements\n",
        "tesla_financials = tesla_ticker.quarterly_financials\n",
        "\n",
        "# The income statement is usually the first dataframe in the financials.\n",
        "# Revenue is typically found under 'Total Revenue' or similar key.\n",
        "# Let's inspect the financials to find the exact key for revenue.\n",
        "print(\"Tesla Quarterly Financials (head):\")\n",
        "display(tesla_financials.head())\n",
        "\n",
        "# Extracting revenue (assuming 'Total Revenue' is the key)\n",
        "# You might need to adjust 'Total Revenue' based on the actual key in the dataframe\n",
        "if 'Total Revenue' in tesla_financials.index:\n",
        "    tesla_revenue_data = tesla_financials.loc['Total Revenue']\n",
        "    print(\"\\nTesla Quarterly Revenue:\")\n",
        "    display(tesla_revenue_data)\n",
        "else:\n",
        "    print(\"\\n'Total Revenue' not found in financial statements index. Please check the `tesla_financials.head()` output for the correct key.\")"
      ],
