    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 413
        },
        "id": "62b13e19",
        "outputId": "18aa1298-b13d-4f26-aed6-91a8bd312b35"
      },
      "source": [
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Ensure the data is sorted by date for proper plotting\n",
        "tesla_revenue_data = tesla_revenue_data.sort_index()\n",
        "\n",
        "plt.figure(figsize=(12, 6))\n",
        "plt.plot(tesla_revenue_data.index, tesla_revenue_data.values, marker='o', linestyle='-')\n",
        "plt.title('Tesla Historical Quarterly Revenue')\n",
        "plt.xlabel('Date')\n",
        "plt.ylabel('Revenue (in USD)')\n",
        "plt.grid(True)\n",
        "plt.xticks(rotation=45) # Rotate date labels for better readability\n",
        "plt.tight_layout() # Adjust layout to prevent labels from overlapping\n",
        "plt.show()"
      ],
      "id": "62b13e19",
      "execution_count": null,
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 1200x600 with 1 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        }
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "76cd4c5c"
      },
      "source": [
        "### Compare Tesla's Revenue with Ford's Revenue"
      ],
      "id": "76cd4c5c"
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 499
        },
        "id": "53302b06",
        "outputId": "677ba445-2f1f-42f4-e11b-d547b4412361"
      },
      "source": [
        "# Get ticker data for Ford\n",
        "ford_ticker = yf.Ticker('F')\n",
        "\n",
        "# Get quarterly financial statements for Ford\n",
        "ford_financials = ford_ticker.quarterly_financials\n",
        "\n",
        "print(\"Ford Quarterly Financials (head):\")\n",
        "display(ford_financials.head())\n",
        "\n",
        "# Extracting revenue for Ford\n",
        "if 'Total Revenue' in ford_financials.index:\n",
        "    ford_revenue_data = ford_financials.loc['Total Revenue']\n",
        "    print(\"\\nFord Quarterly Revenue:\")\n",
        "    display(ford_revenue_data)\n",
        "else:\n",
        "    print(\"\\n'Total Revenue' not found in Ford's financial statements index. Please check the `ford_financials.head()` output for the correct key.\")"
      ],
      "id": "53302b06",
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
