        },
        "id": "081d72ee",
        "outputId": "cc3914fe-1e6f-4850-86ff-edf0dd56c9d4"
      },
      "source": [
        "# Ensure both datasets are sorted by date\n",
        "tesla_revenue_data = tesla_revenue_data.sort_index()\n",
        "ford_revenue_data = ford_revenue_data.sort_index()\n",
        "\n",
        "# Combine the revenue data into a single DataFrame for easier plotting\n",
        "# We'll use the 'Date' index from both Series and align them\n",
        "combined_revenue_df = pd.DataFrame({\n",
        "    'Tesla': tesla_revenue_data,\n",
        "    'Ford': ford_revenue_data\n",
        "}).dropna()\n",
        "\n",
        "# Plotting the combined data\n",
        "plt.figure(figsize=(14, 7))\n",
        "plt.plot(combined_revenue_df.index, combined_revenue_df['Tesla'], marker='o', linestyle='-', label='Tesla Revenue')\n",
        "plt.plot(combined_revenue_df.index, combined_revenue_df['Ford'], marker='x', linestyle='--', label='Ford Revenue')\n",
        "\n",
        "plt.title('Tesla vs. Ford Historical Quarterly Revenue Comparison')\n",
        "plt.xlabel('Date')\n",
        "plt.ylabel('Revenue (in USD)')\n",
        "plt.grid(True)\n",
        "plt.xticks(rotation=45) # Rotate date labels for better readability\n",
        "plt.legend()\n",
        "plt.tight_layout() # Adjust layout to prevent labels from overlapping\n",
        "plt.show()"
      ],
      "id": "081d72ee",
      "execution_count": null,
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 1400x700 with 1 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        }
      ]
    },
