      "source": [
        "from decorator import append\n",
        "for row in rows[1:]:# skip header\n",
        "  cols=row.find_all(\"td\")\n",
        "  if len(cols)==2:\n",
        "     date=cols[0].text.strip()\n",
        "     revenue=cols[1].text.strip().replace(\"$\",\"\").replace(\",\",\"\")\n",
        "     data.append([date,revenue])"
      ],
